@page
@model ChangePasswordModel

@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="space-y-6">

    <!-- Header -->
    <div>
        <h2 class="text-lg font-semibold">Change Password</h2>
        <p class="text-sm opacity-70">Update your account password</p>
    </div>

    <!-- Status Message -->
    <partial name="_StatusMessage" for="StatusMessage"/>

    <form id="change-password-form" method="post" class="space-y-4">

        <!-- Validation -->
        <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

        <!-- Current Password -->
        <div class="form-control">
            <label class="label">
                <span class="label-text">Current Password</span>
            </label>
            <input asp-for="Input.OldPassword"
                   type="password"
                   class="input input-bordered w-full"
                   placeholder="Enter current password"
                   autocomplete="current-password"/>
            <span asp-validation-for="Input.OldPassword" class="text-error text-sm"></span>
        </div>

        <!-- New Password -->
        <div class="form-control">
            <label class="label">
                <span class="label-text">New Password</span>
            </label>
            <input asp-for="Input.NewPassword"
                   type="password"
                   class="input input-bordered w-full"
                   placeholder="Enter new password"
                   autocomplete="new-password"/>
            <span asp-validation-for="Input.NewPassword" class="text-error text-sm"></span>
        </div>

        <!-- Confirm Password -->
        <div class="form-control">
            <label class="label">
                <span class="label-text">Confirm Password</span>
            </label>
            <input asp-for="Input.ConfirmPassword"
                   type="password"
                   class="input input-bordered w-full"
                   placeholder="Confirm new password"
                   autocomplete="new-password"/>
            <span asp-validation-for="Input.ConfirmPassword" class="text-error text-sm"></span>
        </div>

        <!-- Submit -->
        <div class="pt-2">
            <button type="submit"
                    class="btn btn-primary w-full">
                Update Password
            </button>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
