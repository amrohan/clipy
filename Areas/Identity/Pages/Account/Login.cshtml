@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
    ViewData["HideNavbar"] = true;
}

<div class="min-h-screen flex flex-col gap-4 items-center justify-center bg-base-200 px-4">
    <partial name="_BackToHome"/>
    <div class="w-full max-w-md">

        <div class="card bg-base-100 shadow-xl">
            <div class="card-body">

                <h2 class="text-2xl font-bold text-center">Welcome Back </h2>
                <p class="text-center text-sm opacity-70 mb-4">
                    Login to your account
                </p>

                <!-- Validation -->
                <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

                <form method="post" class="space-y-4">

                    <!-- Email -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Email</span>
                        </label>
                        <input asp-for="Input.Email"
                               class="input input-bordered w-full"
                               placeholder="name@example.com"
                               autocomplete="username"/>
                        <span asp-validation-for="Input.Email" class="text-error text-sm"></span>
                    </div>

                    <!-- Password -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Password</span>
                        </label>
                        <input asp-for="Input.Password"
                               type="password"
                               class="input input-bordered w-full"
                               placeholder="••••••••"
                               autocomplete="current-password"/>
                        <span asp-validation-for="Input.Password" class="text-error text-sm"></span>
                    </div>

                    <!-- Remember Me -->
                    <div class="form-control">
                        <label class="label cursor-pointer justify-start gap-2">
                            <input type="checkbox"
                                   class="checkbox checkbox-primary"
                                   asp-for="Input.RememberMe"/>
                            <span class="label-text">
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </span>
                        </label>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn btn-primary w-full">
                        Log in
                    </button>

                    <!-- Links -->
                    <div class="text-sm text-center space-y-1 mt-3">
                        <p>
                            <a asp-page="./ForgotPassword" class="link link-hover">
                                Forgot password?
                            </a>
                        </p>
                        <p>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="link link-primary">
                                Create an account
                            </a>
                        </p>
                        <p>
                            <a asp-page="./ResendEmailConfirmation" class="link link-hover">
                                Resend confirmation email
                            </a>
                        </p>
                    </div>

                </form>

                <!-- External Login -->
                @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <div class="divider">OR</div>

                    <form asp-page="./ExternalLogin"
                          asp-route-returnUrl="@Model.ReturnUrl"
                          method="post"
                          class="space-y-2">

                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit"
                                    name="provider"
                                    value="@provider.Name"
                                    class="btn btn-outline w-full">
                                Continue with @provider.DisplayName
                            </button>
                        }
                    </form>
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
