@page
@model ResetPasswordModel

@{
    ViewData["Title"] = "Reset Password";
    ViewData["HideNavbar"] = true;
}

<div class="min-h-screen flex flex-col items-center justify-center bg-base-200 px-4">
    <partial name="_BackToHome"/>

    <div class="w-full max-w-md">

        <div class="card bg-base-100 shadow-xl">
            <div class="card-body">

                <!-- Header -->
                <h2 class="text-2xl font-bold text-center">Reset Password </h2>
                <p class="text-center text-sm opacity-70 mb-4">
                    Enter your new password below
                </p>

                <!-- Validation -->
                <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

                <form method="post" class="space-y-4">

                    <!-- Hidden Token -->
                    <input asp-for="Input.Code" type="hidden"/>

                    <!-- Email -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Email</span>
                        </label>
                        <input asp-for="Input.Email"
                               class="input input-bordered w-full"
                               placeholder="name@example.com"
                               autocomplete="username"/>
                        <span asp-validation-for="Input.Email" class="text-error text-sm"></span>
                    </div>

                    <!-- Password -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">New Password</span>
                        </label>
                        <input asp-for="Input.Password"
                               type="password"
                               class="input input-bordered w-full"
                               placeholder="Enter new password"
                               autocomplete="new-password"/>
                        <span asp-validation-for="Input.Password" class="text-error text-sm"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Confirm Password</span>
                        </label>
                        <input asp-for="Input.ConfirmPassword"
                               type="password"
                               class="input input-bordered w-full"
                               placeholder="Confirm new password"
                               autocomplete="new-password"/>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-error text-sm"></span>
                    </div>

                    <!-- Submit -->
                    <button type="submit"
                            class="btn btn-primary w-full">
                        Reset Password
                    </button>

                </form>

            </div>
        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
