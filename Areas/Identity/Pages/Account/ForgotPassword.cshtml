@page
@model ForgotPasswordModel

@{
    ViewData["Title"] = "Forgot Password";
    ViewData["HideNavbar"] = true;
}

<div class="min-h-screen flex flex-col items-center justify-center bg-base-200 px-4">
    <!-- Back Button -->
    <partial name="_BackToHome"/>

    <div class="w-full max-w-md">

        <div class="card bg-base-100 shadow-xl">
            <div class="card-body space-y-4">

                <!-- Header -->
                <div class="text-center">
                    <h2 class="text-2xl font-bold">Forgot Password</h2>
                    <p class="text-sm opacity-70">
                        Enter your email to receive a reset link
                    </p>
                </div>

                <!-- Validation -->
                <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

                <form method="post" class="space-y-4">

                    <!-- Email -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Email</span>
                        </label>
                        <input asp-for="Input.Email"
                               class="input input-bordered w-full"
                               placeholder="name@example.com"
                               autocomplete="email"/>
                        <span asp-validation-for="Input.Email" class="text-error text-sm"></span>
                    </div>

                    <!-- Submit -->
                    <button type="submit"
                            class="btn btn-primary w-full">
                        Send Reset Link
                    </button>

                </form>

            </div>
        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
