@page
@model IndexModel
@{
    ViewData["Title"] = "Clipy - Instant Notes Sharing";
}

<main>
    <!-- Hero Section -->
    <header>
        <h1>Welcome to <strong>Clipy</strong></h1>
        <p class="lead">
            Share your notes instantly with a simple URL — no signup, no clutter, just notes.
            <br><br>
            Create a quick note, share the link, and let others view it right away.
            You can even mark notes to self-destruct after being viewed once for extra privacy.
            Perfect for sharing temporary passwords, messages, or short snippets securely.
        </p>
    </header>

    <!-- CTA Buttons -->
    <div class="button-group">
        <a href="/AddNote" role="button" style="width:100%">Create Note</a>
        <a href="/ViewNote" role="button" class="contrast" style="width:100%">View Note</a>
    </div>

    <!-- How It Works -->
    <section style="margin-top:4rem;">
        <h3>How It Works</h3>
        <details open>
            <summary>1. Write your note</summary>
            <p>Go to the “Add Note” page, type your message, and choose whether to delete it after one view for privacy.
            </p>
        </details>

        <details>
            <summary>2. Get your shareable link</summary>
            <p>Once you save your note, you’ll get a unique URL. Share it with anyone — no login required.</p>
        </details>

        <details>
            <summary>3. View securely</summary>
            <p>Anyone with the link can view the note. If you enabled “Delete after view,” the note is permanently
                deleted after it’s read once.</p>
        </details>
    </section>

</main>

<!-- Footer -->
<footer role="contentinfo" style="text-align:center; margin-top:3rem; font-size:0.95rem; opacity:0.85;">
    <p>
        &copy; 2025 — <strong>Clipy</strong> —
        Notes made fun, not creepy.
        <a asp-page="/Privacy">Privacy</a> ·
        Made by <a href="https://amrohan.in" target="_blank" rel="noopener">@@amrohan</a>
    </p>
</footer>


<style>
    .button-group {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: center;
        justify-content: center;
        margin-top: 2rem;
    }

    @@media (min-width: 640px) {
        .button-group {
            width: 60%;
            flex-direction: row;
            margin: 10 auto;
        }
    }

    details {
        margin: 1rem 0;
        border: 1px solid var(--muted-border-color);
        border-radius: 8px;
        padding: 0.8rem 1rem;
        background-color: var(--surface-2);
    }

    details summary {
        font-weight: bold;
        cursor: pointer;
    }

    details[open] summary {
        color: var(--primary);
    }
</style>