        <!-- Desktop Menu -->
        <div class="navbar-end hidden lg:flex w-full">
            <ul class="flex justify-end items-center gap-4 ">
                @if (@User.Identity is { IsAuthenticated: true })
                {
                    <li class="p-1.5">
                        <a asp-page="/MyNotes">My Notes</a>
                    </li>
                }
                else
                {
                    <li class="p-1.5">
                        <a asp-page="/AddNote">Create Note</a>
                    </li>
                }

                <li class="p-1.5">
