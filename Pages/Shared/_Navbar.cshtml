

@{
    var path = Context.Request.Path;
}

<header class="sticky top-2 z-[999] bg-base-100/70 backdrop-blur  rounded-lg">
    <div class="navbar max-w-6xl mx-none md:mx-auto">
        <div class="flex w-full justify-between items-center">
            @if (path != "/" && path != "/MyNotes")
            {
                <partial name="_BackToHome"/>
            }
            <!-- Mobile Menu -->

            <div class="navbar-end w-full lg:hidden">
                <partial name="_UserProfile"/>
                <div class="dropdown">
                    <label tabindex="0" class="btn btn-ghost btn-circle">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none"
                             viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  stroke-width="2"
                                  d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    </label>

                    <ul tabindex="0"
                        class="menu menu-sm dropdown-content mt-2 right-4 z-10 p-2 shadow-lg bg-base-100 border border-base-200 rounded-box w-52">

                        @if (@User.Identity is { IsAuthenticated: true })
                        {
                            <li class="p-1.5">
                                <a asp-page="/MyNotes">My Notes</a>
                            </li>
                        }
                        else
                        {
                            <li class="p-1.5">
                                <a asp-page="/AddNote">Create Note</a>
                            </li>
                        }
                        <li class="p-1.5">
                            <a asp-page="/ViewNote">View Note</a>
                        </li>

                        <li class="p-1.5">
                            <a asp-page="/Room">Start Room</a>
                        </li>

                    </ul>
                </div>
            </div>
        </div>

        <!-- Desktop Menu -->
        <div class="navbar-end hidden lg:flex w-full">
            <ul class="flex justify-end items-center gap-4 ">
                @if (@User.Identity is { IsAuthenticated: true })
                {
                    <li class="p-1.5">
                        <a asp-page="/MyNotes">My Notes</a>
                    </li>
                }
                else
                {
                    <li class="p-1.5">
                        <a asp-page="/AddNote">Create Note</a>
                    </li>
                }

                <li class="p-1.5">
                    <a asp-page="/ViewNote">View Note</a>
                </li>

                <li>
                    <a asp-page="/Room">
                        Start Room
                    </a>
                </li>

                <li>
                    <partial name="_UserProfile"/>
                </li>

            </ul>
        </div>

    </div>
</header>
