@page
@model ViewNoteModel
@using Markdig

@{
    ViewData["Title"] = "View Note";

    var pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    var htmlContent = Model.Note != null
        ? Markdown.ToHtml(Model.Note.Content ?? "", pipeline)
        : "";
}

<div class="max-w-6xl mx-auto p-4 min-h-[70dvh]">
    @if (Model.RequiresPassword)
    {
        <div class="card bg-base-100 border border-base-300">
            <div class="card-body">

                <h2 class="card-title">Password Required</h2>

                <p class="text-base-content/70">
                    This note is protected. Enter the password to continue.
                </p>

                <form method="post" asp-page-handler="Password" id="passwordForm" class="space-y-4">

                    <input type="hidden" name="Code" value="@Model.Code"/>

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Password</legend>

                        <input type="password" name="SubmittedPassword" id="SubmittedPassword"
                               placeholder="Enter password"
                               class="input input-bordered w-full" required
                               @(Model.PasswordAttempted ? "autofocus aria-invalid=true" : "")>

                        @if (Model.PasswordAttempted)
                        {
                            <p class="text-error text-sm mt-1">
                                Incorrect password. Please try again.
                            </p>
                        }

                    </fieldset>

                    <button type="submit" id="unlockBtn" class="btn btn-primary w-full">
                        Unlock Note
                    </button>

                </form>

            </div>
        </div>
    }

    else if (Model.ShowConfirmation)
    {
        <div class="card bg-base-100 border border-base-300">
            <div class="card-body">

                <h2 class="card-title">Confirm View</h2>

                <div class="alert alert-warning">
                    <span>
                        ⚠ This note will be permanently deleted after you view it.
                    </span>
                </div>

                <p class="text-base-content/70">
                    To avoid accidental opening, please confirm you really want to view this note.
                    Once opened, the note cannot be recovered.
                </p>

                <form method="post" asp-page-handler="Confirm" id="confirmForm">

                    <input type="hidden" name="Code" value="@Model.Code"/>

                    <button type="submit" id="confirmBtn" class="btn btn-error w-full">
                        Show Me the Note
                    </button>

                </form>

            </div>
        </div>
    }

    else if (Model.Note != null)
    {
        <div class="card bg-base-100 border border-base-300">

            <div class="card-body">

                <div class="flex justify-between items-center w-full flex-wrap gap-4">

                    <h2 class="card-title">Shared Note</h2>

                    <div class="flex gap-2">

                        @if (Model.Note.FileName != null)
                        {
                            <div class="tooltip" data-tip="Download attached file">
                                <a asp-page="/Download" asp-route-code="@Model.Note.Code"
                                   class="btn btn-primary btn-sm">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                         stroke-linejoin="round"
                                         class="size-4">
                                        <path d="M12 13v8l-4-4"/>
                                        <path d="m12 21 4-4"/>
                                        <path d="M4.393 15.269A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.436 8.284"/>
                                    </svg>
                                    File
                                </a>
                            </div>
                        }

                        <div class="tooltip" data-tip="Download this note">
                            <button id="downloadBtn" class="btn btn-outline btn-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round" class="size-4">
                                    <path
                                        d="m16 6-8.414 8.586a2 2 0 0 0 2.829 2.829l8.414-8.586a4 4 0 1 0-5.657-5.657l-8.379 8.551a6 6 0 1 0 8.485 8.485l8.379-8.551"/>
                                </svg>
                                Note
                            </button>
                        </div>

                        <div class="tooltip" data-tip="Copy note content">
                            <button id="copyBtn" class="btn btn-outline btn-sm">
                                Copy
                            </button>
                        </div>

                    </div>

                </div>

                @if (Model.JustViewedDeletableNote)
                {
                    <div class="alert alert-warning mt-3">
                        <span>
                            ⚠ This note will be deleted if you refresh or leave this page.
                        </span>
                    </div>
                }

                <!-- Markdown Render -->
                <div class="mt-6">
                    <textarea id="rawMarkdown" class="hidden">
                        @Model.Note.Content
                    </textarea>
                    <article id="noteContent" class="markdown max-w-none">

                        @Html.Raw(htmlContent)

                    </article>

                </div>

            </div>

        </div>
    }

    else
    {
        <div class="card bg-base-100 border border-base-300">

            <div class="card-body">

                <h2 class="card-title">Find Your Note</h2>

                <p class="text-base-content/70">
                    Enter your note code to view it.
                </p>

                <form method="get" id="codeForm" class="space-y-4">

                    <fieldset class="fieldset">

                        <legend class="fieldset-legend">Note Code</legend>

                        <input type="text" id="Code" name="code" placeholder="Enter your code"
                               class="input input-bordered w-full" required
                               @(Model.AttemptedAndNotFound ? "aria-invalid=true" : "")>

                        @if (Model.AttemptedAndNotFound)
                        {
                            <p class="text-error text-sm mt-1">
                                Note not found. Please check the code.
                            </p>
                        }

                    </fieldset>

                    <button type="submit" id="viewCodeBtn" class="btn btn-primary w-full">
                        View Note
                    </button>

                </form>

            </div>

        </div>
    }

</div>


<footer class="text-center opacity-70 text-sm py-10">

    <p>
        © @Model.CurrentYear — <strong>Clipy</strong> —
        Notes made fun, not creepy.
    </p>

    <div class="flex justify-center gap-4 mt-2">

        <a href="https://github.com/amrohan/clipy" target="_blank" class="link">
            GitHub
        </a>

        <a asp-page="/Privacy" class="link">
            Privacy
        </a>

        <a href="https://amrohan.in" target="_blank" class="link">
            @@amrohan
        </a>

    </div>

</footer>

@section Scripts
{
    <script>
        document.addEventListener("DOMContentLoaded", () => {

            const copyBtn = document.getElementById("copyBtn");
            const downloadBtn = document.getElementById("downloadBtn");
            const noteContent = document.getElementById("noteContent");
            const rawMarkdown = document.getElementById("rawMarkdown");

            if (!noteContent) return;

            const getContent = () => {
                if (rawMarkdown && rawMarkdown.value.trim() !== "") {
                    return rawMarkdown.value;
                }
                return noteContent.innerText;
            };
            // COPY BUTTON
            if (copyBtn) {
                copyBtn.addEventListener("click", async () => {

                    const text = getContent();

                    try {

                        if (navigator.clipboard && window.isSecureContext) {
                            await navigator.clipboard.writeText(text);
                        } else {
                            const temp = document.createElement("textarea");
                            temp.value = text;
                            document.body.appendChild(temp);
                            temp.select();
                            document.execCommand("copy");
                            document.body.removeChild(temp);
                        }

                        const original = copyBtn.innerText;
                        copyBtn.innerText = "Copied ✓";

                        setTimeout(() => {
                            copyBtn.innerText = original;
                        }, 1500);

                    } catch (err) {
                        console.error(err);
                        alert("Unable to copy text");
                    }

                });
            }


            // DOWNLOAD BUTTON
            if (downloadBtn) {
                downloadBtn.addEventListener("click", () => {

                    const text = noteContent.innerText;

                    const blob = new Blob([text], {type: "text/plain;charset=utf-8"});
                    const url = URL.createObjectURL(blob);

                    const a = document.createElement("a");
                    a.href = url;
                    a.download = "clipy-note.txt";

                    document.body.appendChild(a);
                    a.click();

                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);

                });
            }

        });
    </script>
}
