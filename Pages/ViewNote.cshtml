@page
@model ViewNoteModel
@{
    ViewData["Title"] = "View Note";
}

<div class="max-w-5xl mx-auto p-4 min-h-[70dvh]">

    @if (Model.RequiresPassword)
    {
        <div class="card bg-base-100  border border-base-300">
            <div class="card-body">

                <h2 class="card-title">Password Required</h2>
                <p class="text-base-content/70">
                    This note is protected. Enter the password to continue.
                </p>

                <form method="post" asp-page-handler="Password" id="passwordForm" class="space-y-4">

                    <input type="hidden" name="Code" value="@Model.Code"/>

                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Password</legend>

                        <input
                            type="password"
                            name="SubmittedPassword"
                            id="SubmittedPassword"
                            placeholder="Enter password"
                            class="input input-bordered w-full"
                            required
                            @(Model.PasswordAttempted ? "autofocus aria-invalid=true" : "")>

                        @if (Model.PasswordAttempted)
                        {
                            <p class="text-error text-sm mt-1">
                                Incorrect password. Please try again.
                            </p>
                        }

                    </fieldset>

                    <button type="submit" id="unlockBtn" class="btn btn-primary w-full">
                        Unlock Note
                    </button>

                </form>

            </div>
        </div>
    }
    else if (Model.ShowConfirmation)
    {
        <div class="card bg-base-100  border border-base-300">
            <div class="card-body">

                <h2 class="card-title">Confirm View</h2>

                <div class="alert alert-warning">
                    <span>
                        ⚠ This note will be permanently deleted after you view it.
                    </span>
                </div>

                <p class="text-base-content/70">
                    To avoid accidental opening, please confirm you really want to view this note.
                    Once opened, the note cannot be recovered.
                </p>

                <form method="post" asp-page-handler="Confirm" id="confirmForm">

                    <input type="hidden" name="Code" value="@Model.Code"/>

                    <button type="submit" id="confirmBtn" class="btn btn-error w-full">
                        Show Me the Note
                    </button>

                </form>

            </div>
        </div>
    }
    else if (Model.Note != null)
    {
        <div class="card bg-base-100 border border-base-300">

            <div class="card-body">

                <div class="flex justify-between items-center flex-wrap gap-2">

                    <h2 class="card-title">Shared Note</h2>

                    <div class="flex gap-2">

                        @if (Model.Note.FileName != null)
                        {
                            <a
                                asp-page="/Download"
                                asp-route-code="@Model.Note.Code"
                                class="btn btn-outline btn-sm">
                                Download File
                            </a>
                        }

                        <button id="downloadBtn" class="btn btn-outline btn-sm">
                            Download
                        </button>

                        <button id="copyBtn" class="btn btn-outline btn-sm">
                            Copy
                        </button>

                    </div>

                </div>

                @if (Model.JustViewedDeletableNote)
                {
                    <div class="alert alert-warning mt-3">
                        <span>
                            ⚠ This note will be deleted if you refresh or leave this page.
                        </span>
                    </div>
                }

                <div class="mockup-code mt-4">
                    <pre class="px-6 md:px-10"><code id="noteContent">@Model.Note.Content</code></pre>
                </div>

            </div>
        </div>
    }
    else
    {
        <div class="card bg-base-100  border border-base-300">

            <div class="card-body">

                <h2 class="card-title">Find Your Note</h2>
                <p class="text-base-content/70">
                    Enter your note code to view it.
                </p>

                <form method="get" id="codeForm" class="space-y-4">

                    <fieldset class="fieldset">

                        <legend class="fieldset-legend">Note Code</legend>

                        <input
                            type="text"
                            id="Code"
                            name="code"
                            placeholder="Enter your code"
                            class="input input-bordered w-full"
                            required
                            @(Model.AttemptedAndNotFound ? "aria-invalid=true" : "")>

                        @if (Model.AttemptedAndNotFound)
                        {
                            <p class="text-error text-sm mt-1">
                                Note not found. Please check the code.
                            </p>
                        }

                    </fieldset>

                    <button type="submit" id="viewCodeBtn" class="btn btn-primary w-full">
                        View Note
                    </button>

                </form>

            </div>
        </div>
    }

</div>


<footer class="text-center opacity-70 text-sm py-10">

    <p>
        © @Model.CurrentYear — <strong>Clipy</strong> —
        Notes made fun, not creepy.
    </p>

    <div class="flex justify-center gap-4 mt-2">

        <a href="https://github.com/amrohan/clipy" target="_blank" class="link">
            GitHub
        </a>

        <a asp-page="/Privacy" class="link">
            Privacy
        </a>

        <a href="https://amrohan.in" target="_blank" class="link">
            @@amrohan
        </a>

    </div>

</footer>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {

            const copyBtn = document.getElementById("copyBtn");
            const noteContent = document.getElementById("noteContent");

            if (!copyBtn || !noteContent) return;

            copyBtn.addEventListener("click", async () => {

                const text = noteContent.innerText;

                try {

                    if (navigator.clipboard && window.isSecureContext) {

                        await navigator.clipboard.writeText(text);

                    } else {

                        const temp = document.createElement("textarea");
                        temp.value = text;
                        document.body.appendChild(temp);
                        temp.select();
                        document.execCommand("copy");
                        document.body.removeChild(temp);

                    }

                    const original = copyBtn.innerText;
                    copyBtn.innerText = "Copied";

                    setTimeout(() => {
                        copyBtn.innerText = original;
                    }, 1500);

                } catch (err) {
                    console.error(err);
                    alert("Unable to copy text");
                }

            });

        });

    </script>
}
