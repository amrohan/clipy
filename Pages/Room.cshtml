@page
@model Room
@{
    ViewData["Title"] = "Live Room — Clipy";
}

<div class="max-w-5xl mx-auto p-4">

    <section id="joinView">

        <div class="card bg-base-100 border border-base-300 shadow">

            <div class="card-body">

                <h2 class="card-title">Join or Create Room</h2>
                <p class="text-sm opacity-70">
                    Realtime text sharing · Auto expires in 5 minutes
                </p>

                <fieldset class="fieldset">

                    <legend class="fieldset-legend">Room Code</legend>

                    <input
                        id="roomCode"
                        placeholder="Example: AB12"
                        class="input input-bordered w-full"
                        aria-describedby="valid-helper">

                    <label class="label">
                        <span id="valid-helper" class="label-text-alt"></span>
                    </label>

                </fieldset>

                <div class="grid grid-cols-2 gap-3 mt-2">

                    <button id="joinBtn" class="btn btn-primary">
                        Join Room
                    </button>

                    <button id="createBtn" class="btn btn-outline">
                        Create Room
                    </button>

                </div>

            </div>

        </div>

    </section>


    <!-- ROOM VIEW -->

    <section id="roomView" hidden>

        <div class="card bg-base-100 shadow border border-base-300">

            <div class="card-body p-0">

                <!-- ROOM TOOLBAR -->

                <div class="flex justify-between items-center border-b p-3 flex-wrap gap-2">

                    <div class="font-medium">
                        Room:
                        <span id="activeRoom" class="text-primary"></span>
                    </div>

                    <div class="flex gap-2">

                        <button id="copyRoomBtn" class="btn btn-xs btn-outline">
                            Copy Link
                        </button>

                        <button id="copyBtn" class="btn btn-xs btn-outline">
                            Copy Text
                        </button>

                        <button id="downloadBtn" class="btn btn-xs btn-outline">
                            Download
                        </button>

                        <button id="exitBtn" class="btn btn-xs btn-error">
                            Exit
                        </button>

                    </div>

                </div>


                <!-- EDITOR -->

                <div class="p-4 space-y-2">

<textarea
    id="input"
    rows="12"
    class="textarea textarea-bordered w-full font-mono text-sm"
    placeholder="Start typing… everyone in the room sees changes instantly">
</textarea>

                    <!-- Remote Cursor Indicator -->
                    <div id="cursorOverlay" class="text-primary text-xs hidden">
                        👤 Other user cursor
                    </div>

                </div>


                <!-- STATUS BAR -->

                <div class="flex justify-between items-center border-t p-2 text-xs opacity-70">

                    <div id="typing-indicator" hidden>
                        ✍️ Someone is typing...
                    </div>

                    <div>
                        Realtime sync enabled
                    </div>

                </div>

            </div>

        </div>

    </section>

</div>

@section Scripts {

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script src="~/js/room.js"></script>

}
